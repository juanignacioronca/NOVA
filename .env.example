# NOVA — variables de entorno (ver CLAUDE.md §5)
# Copiá este archivo a `.env` y completá las claves que tengas.
# El esqueleto corre SIN claves (modo stub): podés dejar todo vacío.
# `.env` NUNCA se commitea (está en .gitignore).

# --- Nube (free-tier) ---
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

# --- Opus (opcional, auditoría/conductor crítico) ---
ANTHROPIC_API_KEY=

# --- Local ---
# Host de Ollama. Por defecto http://localhost:11434
OLLAMA_HOST=http://localhost:11434
